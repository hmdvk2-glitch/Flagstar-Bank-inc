{
    "compilerOptions":  {
                            "target":  "ES2020",
                            "useDefineForClassFields":  true,
                            "lib":  [
                                        "ES2020",
                                        "DOM",
                                        "DOM.Iterable"
                                    ],
                            "module":  "ESNext",
                            "moduleResolution":  "Bundler",
                            "jsx":  "react-jsx",
                            "strict":  false,
                            "resolveJsonModule":  true,
                            "isolatedModules":  true,
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "allowSyntheticDefaultImports":  true,
                            "noEmit":  true
                        },
    "include":  [
                    "src"
                ],
    "references":  [

                   ],
    "exclude":  [
                    "supabase/functions",
                    "supabase/**/*.ts",
                    "**/*.deno.ts"
                ]
}
